<!DOCTYPE html>
<html lang="en">
<head>
    <%- include("partial/head") %>
    <title>Add Blog</title>
</head>

<body class="bg-light">

    <%- include("partial/nav") %>

<div class="container py-5">

    <div class="row justify-content-center">
        <div class="col-md-9 col-lg-7">

            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">

                <div class="bg-primary text-white text-center py-4">
                    <h2 class="mb-0 fw-bold">Create New Blog</h2>
                    <small class="opacity-75">Share your thoughts with the world</small>
                </div>

                <div class="card-body p-5">

                    <div class="alert alert-info border-0 shadow-sm mb-4">

    <h6 class="fw-bold mb-2">
        Blog Requirements
    </h6>

    <ul class="mb-0 ps-3">
        <li>Blog title must be at least <strong>5 characters</strong>.</li>
        <li>Blog content must be at least <strong>20 characters</strong>.</li>
        <li>Cover image is <strong>optional</strong>.</li>
    </ul>

</div>

                    <form action="/blog" method="POST" enctype="multipart/form-data">

                        <div class="mb-4">
                            <label class="form-label fw-semibold">
                                Cover Image
                            </label>

                            <input
                                type="file"
                                class="form-control form-control-lg"
                                id="coverImage"
                                name="bodyImageURL"
                            >
                        </div>

                       
                        <div class="mb-4">
                            <div class="d-flex justify-content-between align-items-center mb-1">
                                <label class="form-label fw-semibold mb-0">
                                    Blog Title
                                </label>
                                <small id="titleCharIndicator" class="fw-bold text-danger">
                                    0 / 5 characters
                                </small>
                            </div>

                            <input
                                type="text"
                                class="form-control form-control-lg"
                                id="titleInput"
                                name="title"
                                placeholder="Enter a catchy title..."
                                minlength="5"
                                required
                            >
                        </div>

                        <div class="mb-4">
                            <div class="d-flex justify-content-between align-items-center mb-1">
                                <label class="form-label fw-semibold mb-0">
                                    Blog Content
                                </label>
                                <small id="bodyCharIndicator" class="fw-bold text-danger">
                                    0 / 20 characters
                                </small>
                            </div>

                            <textarea
                                class="form-control"
                                id="bodyInput"
                                name="body"
                                rows="7"
                                placeholder="Write your blog in detail..."
                                style="resize: none;"
                                minlength="20"
                                required
                            ></textarea>
                        </div>

                        <div class="d-grid">
                            <button id="submitBtn" class="btn btn-primary btn-lg rounded-3 fw-semibold" disabled>
                                Publish Blog
                            </button>
                        </div>

                    </form>

                </div>

            </div>

        </div>
    </div>

</div>

<%- include("partial/script") %>


<script>
    document.addEventListener("DOMContentLoaded", function () {
        const titleInput = document.getElementById("titleInput");
        const titleIndicator = document.getElementById("titleCharIndicator");

        const bodyInput = document.getElementById("bodyInput");
        const bodyIndicator = document.getElementById("bodyCharIndicator");

        const submitBtn = document.getElementById("submitBtn");

        function updateFormState() {
            const titleLen = titleInput ? titleInput.value.length : 0;
            const bodyLen = bodyInput ? bodyInput.value.length : 0;

            const isTitleValid = titleLen >= 5;
            const isBodyValid = bodyLen >= 20;

            if (titleIndicator) {
                titleIndicator.textContent = titleLen + " / 5 characters";
                if (isTitleValid) {
                    titleIndicator.classList.remove("text-danger");
                    titleIndicator.classList.add("text-success");
                } else {
                    titleIndicator.classList.remove("text-success");
                    titleIndicator.classList.add("text-danger");
                }
            }

            if (bodyIndicator) {
                bodyIndicator.textContent = bodyLen + " / 20 characters";
                if (isBodyValid) {
                    bodyIndicator.classList.remove("text-danger");
                    bodyIndicator.classList.add("text-success");
                } else {
                    bodyIndicator.classList.remove("text-success");
                    bodyIndicator.classList.add("text-danger");
                }
            }

           
            if (submitBtn) {
                if (isTitleValid && isBodyValid) {
                    submitBtn.removeAttribute("disabled");
                } else {
                    submitBtn.setAttribute("disabled", "true");
                }
            }
        }

        if (titleInput) {
            titleInput.addEventListener("input", updateFormState);
        }

        if (bodyInput) {
            bodyInput.addEventListener("input", updateFormState);
        }

        updateFormState();
    });
</script>
</body>
</html>
