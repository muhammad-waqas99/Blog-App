<!DOCTYPE html>
<html lang="en">
<head>
    <%- include("partial/head") %>
    <title>iBlog</title>
</head>

<body class="bg-light">

    <%- include("partial/nav") %>

    <div class="container py-5">

        <div class="text-center mb-5">
            <h1 class="fw-bold">Latest Blogs</h1>
            <p class="text-muted">
                Explore blogs shared by the community
            </p>
        </div>

        <div class="row g-4">

            <% blogs.forEach(blog => { %>

                <div class="col-md-6 col-lg-4">

                    <div class="card h-100 border-0 shadow-sm rounded-4 overflow-hidden">

                        <img
                            src="<%= blog.bodyImageURL %>"
                            class="card-img-top"
                            alt="blog-image"
                            style="height: 220px; object-fit: contain; background:#f8f9fa;"
                        >

                        <div class="card-body d-flex flex-column">

                            <h5 class="card-title fw-bold">
                                <%= blog.title %>
                            </h5>

                            <div class="mt-auto">
                                <a
                                    href="/blog/<%= blog._id %>"
                                    class="btn btn-primary w-100 rounded-3"
                                >
                                    View Blog
                                </a>
                            </div>

                        </div>

                    </div>

                </div>

            <% }) %>

        </div>

    </div>

    <%- include("partial/script") %>

</body>
</html>