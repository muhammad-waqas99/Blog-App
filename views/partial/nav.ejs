<nav class="navbar navbar-expand-lg bg-body-tertiary border-bottom">
  <div class="container-fluid">

    <a class="navbar-brand fw-bold" href="/">iBlog</a>

    <button class="navbar-toggler" type="button"
      data-bs-toggle="collapse"
      data-bs-target="#navbarNavDropdown">
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="navbarNavDropdown">

      <ul class="navbar-nav">
        <li class="nav-item">
          <a class="nav-link" href="/">Home</a>
        </li>
      </ul>

      <ul class="navbar-nav ms-auto d-flex align-items-center gap-3">

        <% if (locals.user) { %>

          <li class="nav-item">
            <a class="nav-link" href="/blog/add-new">Add Blog</a>
          </li>

          <li class="nav-item dropdown">
            <a class="nav-link dropdown-toggle d-flex align-items-center gap-2 py-1 px-2 rounded-pill" 
               href="#" 
               role="button" 
               data-bs-toggle="dropdown">
              <img
                src="<%= locals.user.userProfileImage %>"
                alt="profile"
                style="width:35px;height:35px;object-fit:cover;border-radius:50%;"
              >
              <span class="fw-medium"><%= locals.user.fullName %></span>
            </a>

            <ul class="dropdown-menu dropdown-menu-end mt-2 shadow-sm">
              <li>
                <a class="dropdown-item" href="/user/profile">
                  Profile
                </a>
              </li>
              <li>
                <a class="dropdown-item" href="/user/logout">
                  Logout
                </a>
              </li>
            </ul>
          </li>

        <% } else { %>

          <li class="nav-item">
            <a class="nav-link" href="/user/signup">Signup</a>
          </li>

          <li class="nav-item">
            <a class="nav-link" href="/user/signin">Login</a>
          </li>

        <% } %>

      </ul>
    </div>
  </div>
</nav>

<% if (locals.error) { %>
  <div class="container mt-3">
    <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
      <%= locals.error %>
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
  </div>
<% } %>