<!DOCTYPE html>
<html lang="en">
<head>
    <%- include("partial/head") %>
    <title>iBlog - Profile</title>
</head>

<body class="bg-light">

    <%- include("partial/nav") %>
<div class="container py-5">

    <div class="row g-4">

        <!-- LEFT SIDE: PROFILE + SETTINGS -->
        <div class="col-lg-4">

            <!-- Profile Card -->
            <div class="card border-0 shadow rounded-4 overflow-hidden mb-4">

                <div class="bg-primary text-white text-center py-5">

                    <img
                        src="<%= user.userProfileImage %>"
                        class="rounded-circle border border-4 border-white shadow"
                        width="120"
                        height="120"
                        style="object-fit: cover;"
                    >

                    <h4 class="mt-3 mb-1 fw-bold">
                        <%= user.fullName %>
                    </h4>

                    <p class="mb-0 small">
                        <%= user.email %>
                    </p>

                </div>

                <div class="card-body">

                    <p class="mb-2">
                        <strong>Full Name:</strong> <%= user.fullName %>
                    </p>

                    <p class="mb-2">
                        <strong>Email:</strong> <%= user.email %>
                    </p>

                    <p class="mb-0">
                        <strong>Joined:</strong>
                        <%= user.createdAt.toLocaleDateString() %>
                    </p>

                </div>

            </div>

            <!-- SETTINGS -->
            <div class="card border-0 shadow rounded-4">

                <div class="card-body">

                    <h5 class="fw-bold mb-3">Settings</h5>

                    <div class="d-grid gap-2">

                        <a href="/user/update-name" class="btn btn-outline-primary">
                            Change Name
                        </a>

                        <a href="/user/update-password" class="btn btn-outline-warning">
                            Change Password
                        </a>

                        <a href="/user/update-profile-image" class="btn btn-outline-success">
                            Update Photo
                        </a>

                    </div>

                </div>

            </div>

        </div>

        <!-- RIGHT SIDE: BLOGS -->
        <div class="col-lg-8">

            <div class="card border-0 shadow rounded-4">

                <div class="card-body p-4">

                    <div class="d-flex justify-content-between align-items-center mb-4">

                        <h4 class="fw-bold mb-0">
                            My Blogs
                        </h4>

                        <span class="badge bg-primary">
                            <%= blogs.length %> Blogs
                        </span>

                    </div>

                    <% if (blogs.length === 0) { %>

                        <div class="text-center py-5">

                            <h5 class="text-muted">No blogs published yet</h5>

                            <a href="/blog/add-new" class="btn btn-primary mt-2">
                                Create First Blog
                            </a>

                        </div>

                    <% } else { %>

                        <div class="row g-3">

                            <% blogs.forEach(blog => { %>

                                <div class="col-md-6">

                                    <div class="card h-100 shadow-sm border-0">

                                        <img
                                            src="<%= blog.bodyImageURL %>"
                                            class="card-img-top"
                                            style="height: 200px; object-fit: cover;"
                                        >

                                        <div class="card-body">

                                            <h6 class="fw-bold">
                                                <%= blog.title %>
                                            </h6>

                                            <small class="text-muted">
                                                <%= blog.createdAt.toLocaleDateString() %>
                                            </small>

                                            <div class="mt-2">
                                                <a href="/blog/<%= blog._id %>" class="btn btn-sm btn-primary">
                                                    Read
                                                </a>
                                            </div>

                                        </div>

                                    </div>

                                </div>

                            <% }) %>

                        </div>

                    <% } %>

                </div>

            </div>

        </div>

    </div>

</div>


    <%- include("partial/script") %>

</body>
</html>