<!DOCTYPE html>
<html lang="en">
<head>
    <%- include("partial/head") %>
    <title>iBlog | Sign Up</title>
</head>

<body class="bg-light">

<%- include("partial/nav") %>

<div class="container py-5">

    <div class="row justify-content-center">
        <div class="col-md-7 col-lg-5">

            <div class="card border-0 shadow-lg rounded-4">

             
                <div class="card-header bg-primary text-white text-center py-4 rounded-top-4">
                    <h3 class="mb-0 fw-bold">Create Account</h3>
                    <small class="opacity-75">Join iBlog community</small>
                </div>

                <div class="card-body p-4 p-md-5">

                    <form action="/user/signup" method="post"  enctype="multipart/form-data">


                        <div class="mt-4">
                            <label for="userProfileImage">Profile Image  (Optional)</label>
                            <input type="file" name="userProfileImage" id="userProfileImage">
                        </div>

         
                        <div class="mb-4">
                            <label class="form-label fw-semibold">
                                Full Name
                            </label>

                            <input
                                name="fullName"
                                type="text"
                                class="form-control form-control-lg"
                                placeholder="Enter your full name"
                                required
                            >
                        </div>

         
                        <div class="mb-4">
                            <label class="form-label fw-semibold">
                                Email Address
                            </label>

                            <input
                                type="email"
                                name="email"
                                class="form-control form-control-lg"
                                placeholder="Enter your email"
                                required
                            >
                        </div>
                
<div class="mb-4">
    <label class="form-label fw-semibold">
        Password
    </label>

    <input
        type="password"
        name="password"
        id="password"
        class="form-control form-control-lg"
        placeholder="Enter your password"
        required
    >

    <div class="form-check mt-2">
        <input
            class="form-check-input"
            type="checkbox"
            id="showPassword"
        >

        <label class="form-check-label" for="showPassword">
            Show Password
        </label>
    </div>
</div>
                        <div class="d-grid">
                            <button type="submit" class="btn btn-primary btn-lg fw-semibold rounded-3">
                                Sign Up
                            </button>
                        </div>

                    </form>

                </div>

  
                <div class="card-footer text-center bg-white border-0 pb-4">
                    <small class="text-muted">
                        Already have an account?
                        <a href="/user/signin" class="text-primary fw-semibold text-decoration-none">
                            Sign in
                        </a>
                    </small>
                </div>

            </div>

        </div>
    </div>

</div>


<script>
    const passwordInput = document.getElementById("password");
    const showPassword = document.getElementById("showPassword");

    showPassword.addEventListener("change", () => {
        passwordInput.type = showPassword.checked
            ? "text"
            : "password";
    });
</script>

<%- include("partial/script") %>
</body>
</html>